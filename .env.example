# URL of the n8n webhook that powers the "Ask Our AI" chat page.
# The Next.js API route at /api/chat proxies requests to this endpoint.
# See README.md > "Ask Our AI backend" for the expected request/response shape.
CHAT_WEBHOOK_URL=https://your-n8n-instance.example.com/webhook/golden-data-chat

# Public site URL, used for canonical links, sitemap.xml and Open Graph tags.
NEXT_PUBLIC_SITE_URL=https://www.goldendatasystems.com

# Optional: API key for a transactional email service (Resend, Postmark, etc.)
# used by /api/contact to send form submissions. Leave blank to log to console only.
CONTACT_EMAIL_API_KEY=

# Optional: destination address for contact form notifications.
CONTACT_EMAIL_TO=sales@goldendatasystems.com
